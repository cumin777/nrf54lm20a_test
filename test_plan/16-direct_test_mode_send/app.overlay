/ {
	chosen {
		ncs,dtm-uart = &uart20;
	};
};

&uart20 {
	status = "okay";
	current-speed = <19200>;
};

&radio {
	status = "okay";
	/*
	 * XIAO nRF54LM20A does not have a DFE antenna matrix.
	 * Delete dfe-supported to disable direction finding support
	 * and allow the DTM application to build.
	 */
	/delete-property/ dfe-supported;
};
